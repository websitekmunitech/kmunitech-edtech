# Copy to .env for local dev (do NOT commit .env)
# In Render, set these as Environment Variables instead of using a .env file.

# App
NODE_ENV=development
PORT=3000

# CORS (production)
# Comma-separated list of allowed frontend origins
FRONTEND_URLS=http://localhost:5173

# Auth
JWT_SECRET=replace-with-a-strong-secret

# Database (pick ONE approach)

# Option A (recommended on Render/Supabase): single URL
# If your password has special characters, URL-encode it (e.g. ? -> %3F)
DATABASE_URL=postgresql://postgres:URL_ENCODED_PASSWORD@db.<project-ref>.supabase.co:5432/postgres
DB_SSL=true

# SSL verification (recommended for production)
# - Set true AND provide a CA cert from your DB provider (Supabase/Aiven/etc.)
DB_SSL_REJECT_UNAUTHORIZED=true
# Provide the CA cert either inline (\n supported) OR via a file path
# DB_SSL_CA=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
# DB_SSL_CA_PATH=./certs/ca.pem

# Option B: discrete fields
DB_HOST=db.<project-ref>.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASS=replace-with-password
DB_NAME=postgres
DB_SSL=true

# SSL verification (recommended for production)
DB_SSL_REJECT_UNAUTHORIZED=true
# DB_SSL_CA=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
# DB_SSL_CA_PATH=./certs/ca.pem

# Optional: base URL used when returning absolute file URLs
PUBLIC_BASE_URL=http://localhost:3000

# Cloudflare R2 (S3-compatible) - used for lesson video uploads
# Do NOT put these in the frontend.
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Cloudflare recommends "auto" region for R2
R2_REGION=auto
# Signed URL lifetime for playback endpoint
R2_SIGNED_URL_EXPIRES_SECONDS=3600

# Optional: seed admin user on startup
ADMIN_NAME=KMUni Admin
ADMIN_EMAIL=admin@kmuni.com
ADMIN_PASSWORD=replace-with-strong-password
